# Career Radar - local pipeline/integration env
# This file is for local tooling, scripts, and n8n-style integrations.
# Do not commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI enrichment
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# SerpApi Google Jobs ingestion
SERP_API_KEY=your_serpapi_key

# n8n local/self-hosted runtime
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_to_a_strong_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/New_York
